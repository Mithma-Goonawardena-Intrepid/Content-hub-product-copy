{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "preserve",

    /* Path aliases */
    "paths": {
      "~~/*": ["./*"],
      "~/*": ["./*"]
    },

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "lib/utils/**/*.ts",
    "lib/types/Image.ts",
    "lib/types/Contentstack/ContentTypes/Common.ts",
    "lib/types/Contentstack/ContentTypes/Picture.ts",
    "lib/types/Contentstack/ContentTypes/Product.ts",
    "lib/types/Contentstack/ContentTypes/ProductInformation.ts",
    "lib/types/Contentstack/ContentTypes/ProductItinerary.ts",
    "lib/types/Contentstack/ContentTypes/TripItineraryDay.ts",
    "lib/types/Contentstack/GlobalFields/ElementsRef.ts",
    "lib/types/Contentstack/GlobalFields/ProductPoint.ts",
    "server/**/*.ts",
    "nuxt-app/**/*.vue",
    "nuxt.config.ts"
  ]
}